{
  "name": "rolie-polie-olie",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "check": "bun run lint && bun run fmt:check && bun run typecheck"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "discord.js": "^14.16.0",
    "hono": "^4.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "typescript": "^5.6.0"
  }
}
