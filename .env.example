# Discord bot credentials
RPO_DISCORD_TOKEN=your_discord_bot_token_here
RPO_DISCORD_CLIENT_ID=your_discord_client_id_here

# OAuth2 client secret for admin login (Discord Developer Portal → OAuth2)
RPO_DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# Public-facing URL where this server is reachable. Used to build the OAuth
# redirect URI: ${RPO_PUBLIC_URL}/api/auth/discord/callback — add that exact URI
# to your Discord application's OAuth2 redirects.
RPO_PUBLIC_URL=http://localhost:3000

# Comma-delimited list of Discord user IDs (snowflakes) allowed to sign in to
# the admin UI. Right-click your username in Discord (with Developer Mode on)
# and choose "Copy User ID".
RPO_ADMIN_USER_IDS=

# Storage
RPO_DATABASE_PATH=./data/rolebot.sqlite

# HTTP server port
RPO_PORT=3000
